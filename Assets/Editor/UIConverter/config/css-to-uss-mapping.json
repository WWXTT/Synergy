{
  "version": "1.0",
  "description": "CSS property to USS property mapping configuration",
  "directProperties": [
    "width",
    "height",
    "min-width",
    "min-height",
    "max-width",
    "max-height",
    "margin",
    "margin-top",
    "margin-right",
    "margin-bottom",
    "margin-left",
    "padding",
    "padding-top",
    "padding-right",
    "padding-bottom",
    "padding-left",
    "border-width",
    "border-top-width",
    "border-right-width",
    "border-bottom-width",
    "border-left-width",
    "border-color",
    "border-top-color",
    "border-right-color",
    "border-bottom-color",
    "border-left-color",
    "border-radius",
    "border-top-left-radius",
    "border-top-right-radius",
    "border-bottom-right-radius",
    "border-bottom-left-radius",
    "background-color",
    "color",
    "font-size",
    "opacity",
    "visibility",
    "overflow",
    "flex-direction",
    "flex-wrap",
    "justify-content",
    "align-items",
    "align-content",
    "align-self",
    "flex-grow",
    "flex-shrink",
    "flex-basis",
    "order",
    "left",
    "top",
    "right",
    "bottom",
    "white-space",
    "text-overflow",
    "letter-spacing",
    "word-spacing",
    "aspect-ratio"
  ],
  "propertyTransforms": {
    "display": {
      "transform": "mapValue",
      "valueMap": {
        "flex": "flex",
        "none": "none",
        "block": "flex",
        "inline": "flex",
        "inline-block": "flex"
      },
      "note": "block/inline/inline-block转换为flex"
    },
    "position": {
      "transform": "filterValue",
      "allowedValues": ["absolute", "relative"],
      "warning": "position: fixed/sticky 不支持，将转换为relative"
    },
    "text-align": {
      "transform": "renameProperty",
      "newName": "-unity-text-align",
      "valueMap": {
        "left": "middle-left",
        "center": "middle-center",
        "right": "middle-right",
        "justify": "middle-center"
      }
    },
    "font-weight": {
      "transform": "renameProperty",
      "newName": "-unity-font-style",
      "valueMap": {
        "normal": "normal",
        "bold": "bold",
        "bolder": "bold",
        "lighter": "normal",
        "100": "normal",
        "200": "normal",
        "300": "normal",
        "400": "normal",
        "500": "normal",
        "600": "bold",
        "700": "bold",
        "800": "bold",
        "900": "bold"
      }
    },
    "font-style": {
      "transform": "renameProperty",
      "newName": "-unity-font-style",
      "valueMap": {
        "normal": "normal",
        "italic": "italic"
      },
      "combine": true,
      "note": "需要与font-weight合并处理"
    },
    "background-image": {
      "transform": "convertUrl",
      "newName": "background-image",
      "urlFormat": "resource('')",
      "note": "CSS url()转换为Unity resource()格式"
    },
    "cursor": {
      "transform": "warn",
      "warning": "cursor属性在Runtime UI中不支持关键字值，需要使用纹理"
    },
    "gap": {
      "transform": "convertToMargin",
      "note": "gap不支持，需要转换为子元素的margin"
    },
    "row-gap": {
      "transform": "convertToMargin",
      "note": "row-gap不支持，需要转换为子元素的margin"
    },
    "column-gap": {
      "transform": "convertToMargin",
      "note": "column-gap不支持，需要转换为子元素的margin"
    },
    "flex": {
      "transform": "expandShorthand",
      "note": "flex简写需要展开为flex-grow, flex-shrink, flex-basis"
    },
    "margin": {
      "transform": "expandShorthand",
      "note": "margin简写可能需要展开"
    },
    "padding": {
      "transform": "expandShorthand",
      "note": "padding简写可能需要展开"
    },
    "border-radius": {
      "transform": "expandShorthand",
      "note": "border-radius简写可能需要展开"
    },
    "border-width": {
      "transform": "expandShorthand",
      "note": "border-width简写可能需要展开"
    },
    "border-color": {
      "transform": "expandShorthand",
      "note": "border-color简写可能需要展开"
    }
  },
  "unitySpecificProperties": {
    "-unity-font": {
      "type": "resource",
      "description": "字体资源引用"
    },
    "-unity-font-definition": {
      "type": "resource",
      "description": "字体定义资源引用"
    },
    "-unity-font-style": {
      "type": "enum",
      "values": ["normal", "italic", "bold", "bold-and-italic"],
      "description": "字体样式"
    },
    "-unity-text-align": {
      "type": "enum",
      "values": [
        "upper-left",
        "upper-center",
        "upper-right",
        "middle-left",
        "middle-center",
        "middle-right",
        "lower-left",
        "lower-center",
        "lower-right"
      ],
      "description": "文本对齐"
    },
    "-unity-text-outline-width": {
      "type": "length",
      "description": "文本描边宽度"
    },
    "-unity-text-outline-color": {
      "type": "color",
      "description": "文本描边颜色"
    },
    "-unity-background-scale-mode": {
      "type": "enum",
      "values": ["stretch-to-fill", "scale-and-crop", "scale-to-fit"],
      "description": "背景缩放模式"
    },
    "-unity-slice-left": {
      "type": "integer",
      "description": "9-slice左边距"
    },
    "-unity-slice-top": {
      "type": "integer",
      "description": "9-slice上边距"
    },
    "-unity-slice-right": {
      "type": "integer",
      "description": "9-slice右边距"
    },
    "-unity-slice-bottom": {
      "type": "integer",
      "description": "9-slice下边距"
    },
    "-unity-material": {
      "type": "resource",
      "description": "材质资源引用"
    }
  },
  "unsupportedProperties": [
    {
      "property": "display",
      "values": ["grid", "inline-grid"],
      "alternative": "使用Flexbox布局替代",
      "severity": "error"
    },
    {
      "property": "position",
      "values": ["fixed", "sticky"],
      "alternative": "使用absolute或relative定位",
      "severity": "warning"
    },
    {
      "property": "float",
      "values": ["*"],
      "alternative": "使用Flexbox布局替代",
      "severity": "error"
    },
    {
      "property": "clear",
      "values": ["*"],
      "alternative": "使用Flexbox布局替代",
      "severity": "error"
    },
    {
      "property": "box-shadow",
      "values": ["*"],
      "alternative": "使用多层元素或9-slice图片模拟",
      "severity": "warning"
    },
    {
      "property": "filter",
      "values": ["*"],
      "alternative": "使用-unity-material或shader",
      "severity": "warning"
    },
    {
      "property": "transform",
      "values": ["*"],
      "alternative": "部分支持，建议避免复杂变换",
      "severity": "warning"
    },
    {
      "property": "transition",
      "values": ["*"],
      "alternative": "USS支持transition但有差异",
      "severity": "info"
    },
    {
      "property": "animation",
      "values": ["*"],
      "alternative": "使用USS transition或代码动画",
      "severity": "warning"
    },
    {
      "property": "background",
      "values": ["linear-gradient(*)", "radial-gradient(*)"],
      "alternative": "使用纯色或图片",
      "severity": "warning"
    },
    {
      "property": "background-size",
      "values": ["*"],
      "alternative": "使用-unity-background-scale-mode",
      "severity": "info"
    },
    {
      "property": "background-position",
      "values": ["*"],
      "alternative": "Unity不支持背景定位",
      "severity": "info"
    },
    {
      "property": "clip-path",
      "values": ["*"],
      "alternative": "不支持",
      "severity": "error"
    },
    {
      "property": "mask",
      "values": ["*"],
      "alternative": "不支持",
      "severity": "error"
    },
    {
      "property": "mix-blend-mode",
      "values": ["*"],
      "alternative": "不支持",
      "severity": "error"
    },
    {
      "property": "isolation",
      "values": ["*"],
      "alternative": "不支持",
      "severity": "error"
    }
  ],
  "unsupportedSelectors": [
    {
      "selector": "::before",
      "alternative": "手动添加子元素",
      "severity": "error"
    },
    {
      "selector": "::after",
      "alternative": "手动添加子元素",
      "severity": "error"
    },
    {
      "selector": "::first-line",
      "alternative": "不支持",
      "severity": "error"
    },
    {
      "selector": "::first-letter",
      "alternative": "不支持",
      "severity": "error"
    },
    {
      "selector": "::selection",
      "alternative": "不支持",
      "severity": "error"
    },
    {
      "selector": ":hover",
      "alternative": "使用USS伪类或代码处理",
      "severity": "warning"
    },
    {
      "selector": ":active",
      "alternative": "使用USS伪类或代码处理",
      "severity": "warning"
    },
    {
      "selector": ":focus",
      "alternative": "使用USS伪类:focus和:focus-visible",
      "severity": "info"
    },
    {
      "selector": ":nth-child(*)",
      "alternative": "简化为类选择器",
      "severity": "warning"
    },
    {
      "selector": ":nth-of-type(*)",
      "alternative": "简化为类选择器",
      "severity": "warning"
    },
    {
      "selector": ">>>()",
      "alternative": "使用简化的后代选择器",
      "severity": "warning"
    }
  ],
  "valueConversions": {
    "colors": {
      "hex": "直接支持 #RRGGBB 或 #RRGGBBAA",
      "rgb": "转换为 #RRGGBB",
      "rgba": "转换为 #RRGGBBAA",
      "hsl": "转换为 #RRGGBB",
      "named": "转换为hex值"
    },
    "lengths": {
      "px": "直接支持",
      "%": "直接支持",
      "em": "转换为计算后的px值",
      "rem": "转换为计算后的px值",
      "vw": "不支持，转换为%或px",
      "vh": "不支持，转换为%或px",
      "calc()": "不支持，需要计算后转换为具体值"
    },
    "urls": {
      "url()": "转换为 resource('path') 或 url('project://database/path')"
    }
  }
}
